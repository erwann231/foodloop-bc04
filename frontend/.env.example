# =============================================
# FOODLOOP FRONTEND — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS commit .env.local
# =============================================

# URL de l'API backend
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# URL du backend pour Socket.IO
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Stripe clé publique (commence par pk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Mapbox (optionnel, pour la carte)
NEXT_PUBLIC_MAPBOX_TOKEN=
