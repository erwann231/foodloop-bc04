# ============================================
# FOODLOOP BACKEND — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS commit le fichier .env
# ============================================

# Serveur
PORT=3001
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=foodloop
DB_USER=postgres
DB_PASSWORD=ton_mot_de_passe_ici

# JWT
JWT_SECRET=change_moi_en_une_chaine_aleatoire_longue_et_securisee
JWT_EXPIRES_IN=7d

# Stripe (utiliser les clés TEST pour le workshop)
# Récupérer sur https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_FEE_PERCENT=8

# Frontend (pour CORS)
FRONTEND_URL=http://localhost:3000

# (Optionnel) Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
